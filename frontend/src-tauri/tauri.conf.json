{
  "$schema": "https://raw.githubusercontent.com/nicholasrice/tauri/v2/packages/cli/schema.json",
  "productName": "Sniflo",
  "version": "0.1.1",
  "identifier": "com.sniflo.dev",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Sniflo",
        "width": 1100,
        "height": 700,
        "minWidth": 960,
        "minHeight": 600,
        "theme": "Dark",
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "macOS": {
      "dmg": {
        "background": "icons/dmg-background.png",
        "windowSize": {
          "width": 760,
          "height": 460
        },
        "appPosition": {
          "x": 210,
          "y": 205
        },
        "applicationFolderPosition": {
          "x": 550,
          "y": 205
        }
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
